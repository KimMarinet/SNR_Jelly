generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider          = "mysql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum AssetCategory {
  CHARACTER
  SKILL
  COMMON
}

enum UserRole {
  USER
  ADMIN
}

enum CharacterRole {
  ATTACKER
  MAGIC
  DEFENDER
  SUPPORT
  UNIVERSAL
}

enum CharacterAttackType {
  PHYSICAL
  MAGIC
}

model User {
  id           Int        @id @default(autoincrement())
  email        String     @unique
  passwordHash String?
  nickname     String     @default("new-user")
  role         UserRole   @default(USER)
  adminPreference AdminPreference?
  posts        Post[]
  comments     Comment[]
  postLikes    PostLike[]
  postViews    PostView[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model AdminPreference {
  id                       Int      @id @default(autoincrement())
  userId                   Int      @unique
  heroBackgroundStoredName String?
  heroBackgroundUrl        String?
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model Board {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  title       String
  description String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  isAdminWriteOnly Boolean @default(false)
  isSystemProtected Boolean @default(false)
  posts       Post[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, order])
}

model Post {
  id          Int       @id @default(autoincrement())
  boardId     Int
  authorId    Int
  title       String
  content     String    @db.LongText
  isPublished Boolean   @default(true)
  isPinned    Boolean   @default(false)
  likeCount   Int       @default(0)
  viewCount   Int       @default(0)
  deletedAt   DateTime?
  board       Board     @relation(fields: [boardId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  author      User      @relation(fields: [authorId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  comments    Comment[]
  likes       PostLike[]
  views       PostView[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([boardId])
  @@index([authorId])
  @@index([isPublished, deletedAt])
  @@index([createdAt])
  @@index([isPinned, isPublished, deletedAt])
}

model Comment {
  id        Int      @id @default(autoincrement())
  postId    Int
  authorId  Int
  content   String   @db.Text
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId, createdAt])
  @@index([authorId])
}

model PostLike {
  id        Int      @id @default(autoincrement())
  postId    Int
  userId    Int
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([userId])
}

model PostView {
  id        Int      @id @default(autoincrement())
  postId    Int
  userId    Int
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([userId])
}

model Asset {
  id           Int           @id @default(autoincrement())
  category     AssetCategory @default(COMMON)
  originalName String
  storedName   String        @unique
  mimeType     String
  size         Int
  filePath     String
  publicUrl    String
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([category, deletedAt])
}

model Character {
  id                     Int                 @id @default(autoincrement())
  name                   String              @unique
  portraitOriginalName   String
  portraitStoredName     String              @unique
  portraitMimeType       String
  portraitSize           Int
  portraitFilePath       String
  portraitUrl            String
  skillOneName           String
  skillOneImageOriginalName String
  skillOneImageStoredName String             @unique
  skillOneImageMimeType  String
  skillOneImageSize      Int
  skillOneImageFilePath  String
  skillOneImageUrl       String
  skillTwoName           String
  skillTwoImageOriginalName String
  skillTwoImageStoredName String             @unique
  skillTwoImageMimeType  String
  skillTwoImageSize      Int
  skillTwoImageFilePath  String
  skillTwoImageUrl       String
  skillDescription       String?             @db.Text
  skillTwoDescription    String?             @db.Text
  passiveName            String
  passiveImageOriginalName String
  passiveImageStoredName String              @unique
  passiveImageMimeType   String
  passiveImageSize       Int
  passiveImageFilePath   String
  passiveImageUrl        String
  passiveDescription     String?             @db.Text
  role                   CharacterRole
  roleSymbolUrl          String
  attackType             CharacterAttackType
  attackPower            Int
  defense                Int
  health                 Int
  speed                  Int
  criticalRate           Int
  criticalDamage         Int
  weakPointRate          Int
  blockRate              Int
  damageReduction        Int
  effectAccuracy         Int
  effectResistance       Int
  transcendence          Json
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  @@index([role, createdAt])
}

model LandingVideo {
  id        Int      @id @default(autoincrement())
  title     String?
  youtubeId String   @unique
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, order])
}
