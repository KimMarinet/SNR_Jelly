generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "mysql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum AssetCategory {
  CHARACTER
  SKILL
  COMMON
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  posts     Post[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Board {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  title       String
  description String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  posts       Post[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, order])
}

model Post {
  id          Int       @id @default(autoincrement())
  boardId     Int
  authorId    Int
  title       String
  content     String    @db.LongText
  isPublished Boolean   @default(true)
  deletedAt   DateTime?
  board       Board     @relation(fields: [boardId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  author      User      @relation(fields: [authorId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([boardId])
  @@index([authorId])
  @@index([isPublished, deletedAt])
}

model Asset {
  id           Int           @id @default(autoincrement())
  category     AssetCategory @default(COMMON)
  originalName String
  storedName   String        @unique
  mimeType     String
  size         Int
  filePath     String
  publicUrl    String
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([category, deletedAt])
}
